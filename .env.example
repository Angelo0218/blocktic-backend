# === Database ===
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=blocktic
DB_PASSWORD=blocktic
DB_DATABASE=blocktic

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === JWT ===
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=3600

# === AWS Rekognition (Face Liveness) ===
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# === Google Gemini (ID OCR) ===
GEMINI_API_KEY=your-gemini-api-key

# === CompreFace (Local GPU) ===
COMPREFACE_URL=http://localhost:8000
COMPREFACE_API_KEY=your-compreface-api-key

# === ECPay (Payment) ===
ECPAY_MERCHANT_ID=your-merchant-id
ECPAY_HASH_KEY=your-hash-key
ECPAY_HASH_IV=your-hash-iv

# === Polygon Blockchain ===
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_PRIVATE_KEY=your-deployer-private-key
TICKET_CONTRACT_ADDRESS=0x...
VRF_COORDINATOR_ADDRESS=0x...

# === App ===
NODE_ENV=development
PORT=3000
