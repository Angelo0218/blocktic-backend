# ╔══════════════════════════════════════════════════╗
# ║        BlockTic 開發環境設定                      ║
# ║  複製此檔為 .env，填入實際值                       ║
# ║  cp .env.example .env                            ║
# ╚══════════════════════════════════════════════════╝

# === Database（Docker 內自動指向 postgres 容器）===
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=blocktic
DB_PASSWORD=blocktic
DB_DATABASE=blocktic

# === Redis（Docker 內自動指向 redis 容器）===
REDIS_HOST=redis
REDIS_PORT=6379

# === JWT ===
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_EXPIRATION=86400

# === CompreFace（Docker 內自動指向 compreface-api 容器）===
# 到 http://localhost:8002 的 CompreFace UI 建立 service 後取得 API Key
COMPREFACE_URL=http://compreface-api:8000
COMPREFACE_VERIFY_API_KEY=your-verify-api-key
COMPREFACE_RECOGNIZE_API_KEY=your-recognize-api-key
FACE_MATCH_THRESHOLD=0.85

# === AWS Rekognition（Face Liveness，東京區域）===
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
LIVENESS_CONFIDENCE_THRESHOLD=90
LIVENESS_SHARPNESS_THRESHOLD=30
LIVENESS_BRIGHTNESS_THRESHOLD=20

# === Google Gemini（證件 OCR）===
GEMINI_API_KEY=your-gemini-api-key

# === ECPay 綠界金流 ===
ECPAY_MERCHANT_ID=3002607
ECPAY_HASH_KEY=pwFHCqoQZGmho4w6
ECPAY_HASH_IV=EkRm7iFT261dpevs
ECPAY_RETURN_URL=http://localhost:3000/tickets/ecpay/callback

# === Polygon Blockchain ===
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_PRIVATE_KEY=your-deployer-private-key
SBT_CONTRACT_ADDRESS=0x62b9eDDd189a2435CFd271d99112DF91B2C70026
VRF_COORDINATOR_ADDRESS=0xbD5C5dd467D14101781566cE7C9Ea0Dd6845dD05
BUNDLER_URL=http://localhost:4337
PAYMASTER_URL=http://localhost:4338
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
WALLET_FACTORY_ADDRESS=0x9406Cc6185a346906296840746125a0E44976454

# === App ===
NODE_ENV=development
PORT=3000
